---
import { Image, getImage } from "astro:assets";
import { getPhotos, getAllTags, getAllYears, displayWidth } from "../lib/photos";
import site from "../data/site.json";
import "../styles/global.css";

const photos = getPhotos();
const tags = getAllTags(photos);
const years = getAllYears(photos);

// Pre-render the lightbox variant of each photo, capped at MAX_EDGE
// on the long side — this is the largest image the site ever serves.
const fullSize = await Promise.all(
  photos.map((p) =>
    getImage({
      src: p.image,
      width: displayWidth(p.image),
      format: "webp",
      quality: 85,
    }),
  ),
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive, noimageindex" />
    <meta name="referrer" content="no-referrer" />
    <title>{site.title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Marcellus&family=Newsreader:ital,opsz,wght@0,6..72,300..500;1,6..72,300..500&display=swap"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'><rect x='2' y='2' width='12' height='12' fill='none' stroke='%23191817' stroke-width='1.5'/></svg>"
    />
  </head>
  <body>
    <header class="masthead">
      <h1><a href="/">{site.name}</a></h1>
      <div class="rule" aria-hidden="true"></div>
      <p class="subtitle">Photographs</p>
    </header>

    {
      (tags.length > 0 || years.length > 0) && (
        <nav class="tags" aria-label="Filter photographs by tag">
          <button data-tag="all" aria-pressed="true">
            All <span class="count">{photos.length}</span>
          </button>
          {tags.map(({ tag, count }) => (
            <button data-tag={tag} aria-pressed="false">
              {tag} <span class="count">{count}</span>
            </button>
          ))}
          {years.length > 0 && (
            <>
              <span class="divider" aria-hidden="true" />
              <button id="year-toggle" aria-expanded="false" aria-controls="years">
                <span class="label">Year</span> <span class="chev">▾</span>
              </button>
            </>
          )}
        </nav>
      )
    }
    {
      years.length > 0 && (
        <nav class="years" id="years" hidden aria-label="Filter photographs by year">
          <button data-year="all" aria-pressed="true">
            All years
          </button>
          {years.map(({ year, count }) => (
            <button data-year={String(year)} aria-pressed="false">
              {year} <span class="count">{count}</span>
            </button>
          ))}
        </nav>
      )
    }

    <main>
      <ul class="grid" id="grid">
        {
          photos.map((p, i) => (
            <li
              class="item"
              style={`--ar: ${(p.image.width / p.image.height).toFixed(4)}; --i: ${i};`}
              data-tags={p.tags.join(",")}
              data-year={p.year !== null ? String(p.year) : undefined}
            >
              <a
                class="frame"
                href={fullSize[i].src}
                data-title={p.title}
                data-tags-label={p.tags.join("  ·  ")}
                data-page={`/photo/${p.slug}/`}
              >
                <Image
                  src={p.image}
                  width={Math.min(1000, displayWidth(p.image))}
                  widths={[400, 700, 1000, 1400].filter((w) => w <= displayWidth(p.image))}
                  sizes="(max-width: 700px) 100vw, 60vw"
                  alt={p.alt}
                  loading={i < 6 ? "eager" : "lazy"}
                  decoding="async"
                />
                <span class="caption">{p.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="empty" id="empty" hidden>Nothing here yet.</p>
    </main>

    <footer>
      <div class="rule" aria-hidden="true"></div>
      <p>© {new Date().getFullYear()} {site.name} <span class="foot-sep">·</span> <a href="/about/">About</a></p>
    </footer>

    <dialog id="lightbox" aria-label="Photograph viewer">
      <button class="lb-close" data-close aria-label="Close">×</button>
      <button class="lb-arrow lb-prev" data-prev aria-label="Previous photograph">‹</button>
      <figure>
        <img id="lb-img" src="" alt="" />
        <figcaption>
          <span id="lb-title"></span>
          <span id="lb-tags" class="lb-tags"></span>
          <a id="lb-page" class="lb-page" href="/">photo page</a>
        </figcaption>
      </figure>
      <button class="lb-arrow lb-next" data-next aria-label="Next photograph">›</button>
    </dialog>

    <script>
      // ---- Casual-download deterrent (not real protection) ----
      document.addEventListener("contextmenu", (e) => {
        if (e.target instanceof HTMLImageElement) e.preventDefault();
      });
      document.addEventListener("dragstart", (e) => {
        if (e.target instanceof HTMLImageElement) e.preventDefault();
      });

      // ---- Tag + year filtering (combined with AND) ----
      const tagButtons = [...document.querySelectorAll<HTMLButtonElement>(".tags button[data-tag]")];
      const yearButtons = [...document.querySelectorAll<HTMLButtonElement>(".years button[data-year]")];
      const yearToggle = document.getElementById("year-toggle");
      const yearsNav = document.getElementById("years");
      const items = [...document.querySelectorAll<HTMLLIElement>(".item")];
      const empty = document.getElementById("empty")!;
      let activeTag = "all";
      let activeYear = "all";

      function applyFilters() {
        for (const b of tagButtons) {
          b.setAttribute("aria-pressed", String(b.dataset.tag === activeTag));
        }
        for (const b of yearButtons) {
          b.setAttribute("aria-pressed", String(b.dataset.year === activeYear));
        }
        let visible = 0;
        for (const item of items) {
          const itemTags = (item.dataset.tags ?? "").split(",").filter(Boolean);
          const show =
            (activeTag === "all" || itemTags.includes(activeTag)) &&
            (activeYear === "all" || item.dataset.year === activeYear);
          item.hidden = !show;
          if (show) visible++;
        }
        empty.hidden = visible > 0;
        // Collapsed toggle still shows which year is active.
        if (yearToggle) {
          yearToggle.querySelector(".label")!.textContent = activeYear === "all" ? "Year" : activeYear;
        }
        const params = new URLSearchParams();
        if (activeTag !== "all") params.set("tag", activeTag);
        if (activeYear !== "all") params.set("year", activeYear);
        const query = params.toString();
        history.replaceState(null, "", query ? `#${query}` : location.pathname);
      }

      for (const b of tagButtons) {
        b.addEventListener("click", () => {
          activeTag = b.dataset.tag!;
          applyFilters();
        });
      }
      for (const b of yearButtons) {
        b.addEventListener("click", () => {
          activeYear = b.dataset.year!;
          applyFilters();
        });
      }

      function setYearsOpen(open: boolean) {
        if (!yearToggle || !yearsNav) return;
        yearsNav.hidden = !open;
        yearToggle.setAttribute("aria-expanded", String(open));
      }

      yearToggle?.addEventListener("click", () => setYearsOpen(yearsNav!.hidden));

      const params = new URLSearchParams(location.hash.slice(1));
      const initialTag = params.get("tag");
      const initialYear = params.get("year");
      if (initialTag && tagButtons.some((b) => b.dataset.tag === initialTag)) {
        activeTag = initialTag;
      }
      if (initialYear && yearButtons.some((b) => b.dataset.year === initialYear)) {
        activeYear = initialYear;
        setYearsOpen(true);
      }
      if (activeTag !== "all" || activeYear !== "all") applyFilters();

      // ---- Lightbox ----
      const lightbox = document.getElementById("lightbox") as HTMLDialogElement;
      const lbImg = document.getElementById("lb-img") as HTMLImageElement;
      const lbTitle = document.getElementById("lb-title")!;
      const lbTags = document.getElementById("lb-tags")!;
      const lbPage = document.getElementById("lb-page") as HTMLAnchorElement;
      const frames = [...document.querySelectorAll<HTMLAnchorElement>(".frame")];
      let current = -1;

      function visibleFrames() {
        return frames.filter((f) => !(f.closest(".item") as HTMLLIElement).hidden);
      }

      // Preload the neighbouring full-size images so stepping feels instant.
      const preloaded = new Set<string>();
      function preload(href: string) {
        if (preloaded.has(href)) return;
        preloaded.add(href);
        new Image().src = href;
      }
      function preloadNeighbours() {
        const vis = visibleFrames();
        const pos = vis.indexOf(frames[current]);
        if (pos === -1 || vis.length < 2) return;
        preload(vis[(pos + 1) % vis.length].href);
        preload(vis[(pos - 1 + vis.length) % vis.length].href);
      }

      function show(frame: HTMLAnchorElement) {
        current = frames.indexOf(frame);
        if (lightbox.open && lbImg.src !== frame.href) lbImg.style.opacity = "0";
        lbImg.onload = () => {
          lbImg.style.opacity = "1";
        };
        lbImg.src = frame.href;
        lbImg.alt = frame.querySelector("img")?.alt ?? "";
        lbTitle.textContent = frame.dataset.title ?? "";
        lbTags.textContent = frame.dataset.tagsLabel ?? "";
        lbPage.href = frame.dataset.page ?? "/";
        if (!lightbox.open) lightbox.showModal();
        preloadNeighbours();
      }

      function step(dir: number) {
        const vis = visibleFrames();
        if (vis.length === 0) return;
        const pos = vis.indexOf(frames[current]);
        show(vis[(pos + dir + vis.length) % vis.length]);
      }

      for (const frame of frames) {
        frame.addEventListener("click", (e) => {
          e.preventDefault();
          show(frame);
        });
      }

      lightbox.querySelector("[data-close]")!.addEventListener("click", () => lightbox.close());
      lightbox.querySelector("[data-prev]")!.addEventListener("click", () => step(-1));
      lightbox.querySelector("[data-next]")!.addEventListener("click", () => step(1));

      lightbox.addEventListener("click", (e) => {
        // Click on the dialog backdrop (not its contents) closes it.
        if (e.target === lightbox) lightbox.close();
      });

      document.addEventListener("keydown", (e) => {
        if (!lightbox.open) return;
        if (e.key === "ArrowLeft") step(-1);
        if (e.key === "ArrowRight") step(1);
      });

      // Swipe: left/right to step, down to close.
      let touchX = 0;
      let touchY = 0;
      lightbox.addEventListener(
        "touchstart",
        (e) => {
          touchX = e.touches[0].clientX;
          touchY = e.touches[0].clientY;
        },
        { passive: true },
      );
      lightbox.addEventListener(
        "touchend",
        (e) => {
          const dx = e.changedTouches[0].clientX - touchX;
          const dy = e.changedTouches[0].clientY - touchY;
          if (Math.abs(dx) > 48 && Math.abs(dx) > Math.abs(dy) * 1.5) {
            step(dx < 0 ? 1 : -1);
          } else if (dy > 72 && dy > Math.abs(dx) * 1.5) {
            lightbox.close();
          }
        },
        { passive: true },
      );

      lightbox.addEventListener("close", () => {
        lbImg.src = "";
      });
    </script>
  </body>
</html>
